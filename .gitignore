# Build / local dev (recreated by build.ps1)
tools/
wrapper/bin/
wrapper/obj/
wrapper/out/

# Runtime — created on first launch (never publish to GitHub)
Data/
App/Brave/*
!App/Brave/README.txt

# OS junk
Thumbs.db
desktop.ini
*.log
*.tmp
*.cache

# User-specific / machine-specific
*.user
*.suo
.vs/
.idea/

# Optional PA installer output (build locally, upload separately)
*.paf.exe
Output/

# Temp / debug leftovers
tmp-*
*.bak

# Cursor / editor workspace (local only)
.cursor/
assets/

